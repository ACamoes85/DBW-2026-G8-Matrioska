<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Matrioska - Em Jogo</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/base.css" /> 
    <link rel="stylesheet" href="/css/gamescreen.css" />
</head>
<body class="game-page"> 
    <input type="hidden" id="room-code-hidden" value="<%= sala.codigoSala %>">
    <input type="hidden" id="current-user-id" value="<%= user.id || user._id %>">

    <div class="game-screen">
        <div class="overlay">
            <h1 id="gamescreen-title">Sala de Jogo</h1>

            <div class="game-info">
                <p class="timer" id="game-timer"><%= sala.tempoJogo %>s</p>
                <p class="game-mode" id="game-mode-display">Modo: <%= sala.modoJogo %></p>
                <p class="score-display" id="score-display">Pontuação: 0</p>
            </div>

            <p class="label" id="master-word-label">A palavra é:</p>
            <h2 id="master-word"><%= jogo.palavraMestra %></h2>

            <div class="input-section">
                <input
                    type="text"
                    id="player-word"
                    placeholder="Escreve uma palavra..."
                    autocomplete="off"
                />
                <button id="submit-word-btn">Submeter</button>
            </div>

            <p id="feedback-message"></p>

            <div class="found-words-section">
                <p class="found-words-title" id="found-words-title">
                    Palavras encontradas:
                </p>
                <ul id="found-words-list"></ul>
            </div>

            <p class="room-label" id="game-room-code-label">Código da sala:</p>
            <div class="room-code" id="game-room-code"><%= sala.codigoSala %></div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>

    <script>
        // Dados injetados pelo EJS
        window.DADOS_JOGO = {
            palavraMestra: "<%= jogo.palavraMestra %>",
            subPalavras: <%- JSON.stringify(jogo.subPalavras) %>,
            tempoInicial: <%= sala.tempoJogo %>,
            modoJogo: "<%= sala.modoJogo %>",
            userId: "<%= user.id || user._id %>",
            username: "<%= user.username %>"
        };
    </script>

    <script src="/js/main.js"></script>
    <script src="/js/gamescreen.js"></script>
    
</body>
</html>