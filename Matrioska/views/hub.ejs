<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Matrioska - Hub</title>
    <link rel="stylesheet" href="/css/hub.css">
    <link rel="stylesheet" href="/css/navbar.css">
</head>
<body>

    <header class="header-navbar">
        <nav class="nav-links">
            <a href="/hub" class="active" id="nav-home">Início</a>
            <a href="/leaderboard" id="nav-ranking">Classificação</a>
            <a href="/howtoplay" id="nav-how">Como jogar</a>
        </nav>

        <div class="profile-section">
            <a href="/profile">
                <img src="<%= user ? user.avatar : '/images/profile1.png' %>" alt="Perfil" class="profile-avatar" id="nav-profile-avatar">
            </a>
        </div>
    </header>

    <main class="hero">
        <section class="card">

            <div class="left">
                <h1 id="welcome-label">
                    Bem-vindo, <%= user ? user.username : 'à Matrioska' %>
                </h1>

                <p id="description">Revela o máximo de palavras antes que o tempo se esgote.</p>

                <p id="hub-aviso" style="display:none; color:#ff6b6b; background:rgba(255,80,80,0.1); border:1px solid rgba(255,80,80,0.3); border-radius:8px; padding:10px 14px; font-weight:600; margin-bottom:12px;"></p>

                <button id="btn-create" class="btn btn-main" onclick="window.location.href='/create-match'">
                    Criar partida
                </button>

                <form action="/api/match/create" method="POST" class="join-room">
                    <input 
                        id="room-input" 
                        name="codigoSala" 
                        type="text" 
                        placeholder="Introduzir código da sala" 
                        required
                    >
                    <button type="submit" id="btn-enter-room" class="btn btn-enter">
                        Entrar
                    </button>
                </form>
            </div>

            <div class="right">
                <img src="/images/clock_illustration.png" class="game-image" alt="Jogo Matrioska">
            </div>

            <div class="language">
                <button class="lang-btn" type="button" onclick="toggleLanguage()">
                    <img id="lang-flag" class="flag" src="/images/english_icon.png" alt="Idioma">
                    <span id="lang-name">English</span>
                </button>
            </div>

        </section>
    </main>

    <script src="/js/main.js"></script>
    <script src="/js/hub.js"></script>
</body>
</html>