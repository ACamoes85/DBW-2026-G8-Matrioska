<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Matrioska - Criar Partida</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/create-match.css">
</head>
<body class="create-match-page">
    <a href="/hub" class="back-button">Voltar</a>
    
    <img src="/images/create-match.png" class="background-image" alt="Fundo Criar Partida" />

    <main class="central-container">
        <form action="/api/match/create" method="POST" class="glass-card match-card">
            <h1 class="gradient-title">Criar partida</h1>

            <div class="form-group">
                <label>Modo de Jogo:</label>
                <div class="custom-select">
                    <select id="game-mode" name="modoJogo">
                        <option value="multiplayer">Multijogador</option>
                        <option value="solo">Solo</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label>Tempo Limite:</label>
                <div class="custom-select">
                    <select id="time-limit" name="tempoLimite">
                        <option value="30">30s</option>
                        <option value="60">60s</option>
                    </select>
                </div>
            </div>

            <div class="room-code-section">
                <label>Código da Sala:</label>
                <input type="hidden" id="hidden-room-code" name="codigoSala">
                <div class="code-display" id="room-code">------</div>
            </div>

            <button type="submit" class="btn-create-match" id="btn-confirm-create">Criar</button>
        </form>
    </main>

    <script src="/js/main.js"></script>
    <script src="/js/create-match.js"></script>
</body>
</html>