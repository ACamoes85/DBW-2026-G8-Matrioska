<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Matrioska - Register</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/auth.css" />
  </head>

  <body>
    <img src="/images/homepage_bg.png" alt="Fundo Matrioska" class="background-image" />

    <a href="/" class="auth-back" aria-label="Voltar">←</a>

    <main class="glass-card auth-card">
      <h1 class="title-neon">Matrioska</h1>
      <p class="auth-subtitle" id="register-subtitle">Insere os teus dados</p>

      <form class="auth-form" id="register-form">
        <input type="email" name="email" class="auth-input" id="register-email" placeholder="E-mail" required />
        <input type="text" name="username" class="auth-input" id="register-username" placeholder="Nome de utilizador" required />
        <input type="password" name="password" class="auth-input" id="register-password" placeholder="Palavra-passe" required />
        <input type="password" name="confirmPassword" class="auth-input" id="register-confirm-password" placeholder="Confirmar palavra-passe" required />
        <button type="submit" class="auth-submit register-submit" id="register-button">Registar</button>
      </form>

      <div class="lang-footer" id="lang-selector" onclick="toggleLanguage()">
        <div id="lang-flag" class="lang-icon english-flag"></div>
        <span id="lang-name" class="lang-text">English</span>
      </div>
    </main>

    <script src="/js/main.js"></script>
    <script src="/js/register.js"></script>
  </body>
</html>