<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Matrioska - Classificação</title>
    
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/navbar.css" />
    <link rel="stylesheet" href="/css/leaderboard.css" />
  </head>
  <body>
    <img src="/images/howtoplay_bg.png" class="background-image" alt="Fundo Classificação" />

    <header class="header-navbar">
        <a href="/hub" class="back-button" style="text-decoration: none; color: white; margin-left: 20px;">← Voltar</a>
        <nav class="nav-links">
            <a href="/hub">Início</a>
            <a href="/leaderboard" class="active">Classificação</a>
            <a href="/howtoplay">Como jogar</a>
        </nav>
        <div class="profile-section">
            <a href="/profile" class="profile-link">
                <img src="<%= user ? user.avatar : '/images/profile1.png' %>" alt="Perfil" class="profile-avatar" id="nav-profile-avatar">
            </a>
        </div>
    </header>

    <main class="leaderboard-page">
      <div class="glass-card leaderboard-card">
        <h1 class="title-neon">Classificação</h1>
         <div class="leaderboard-table">
          <div class="table-header">
            <span>Posição</span>
            <span>Jogador</span>
            <span>Pontuação Total</span>
          </div>

          <div class="table-body">
            <% if (typeof players !== 'undefined' && players.length > 0) { %>
              <% players.forEach((player, index) => { %>
                <div class="table-row">
                  <span><%= index + 1 %></span>
                  <span><%= player.username %></span>
                  <span><%= player.stats.totalScore %></span>
                </div>
              <% }); %>
            <% } else { %>
              <div class="table-row">
                <span colspan="3">Ainda não há pontuações registadas.</span>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </main>

    <script src="/js/main.js"></script>
  </body>
</html>