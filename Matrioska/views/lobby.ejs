<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Matrioska - Lobby</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/base.css">
    <link rel="stylesheet" href="/css/create-match.css">
    <link rel="stylesheet" href="/css/lobby.css">
</head>
<body class="create-match-page">

    <% if (user) { %>
        <input type="hidden" id="current-user-id" value="<%= String(user.id || user._id) %>">
        <span id="player-username-display" style="display:none;"><%= user.username %></span>
    <% } %>

    <img src="/images/create-match.png" class="background-image" alt="Fundo">

    <a href="/hub" class="back-button">
        <span>←</span> <span class="txt-back">Voltar</span>
    </a>

    <main class="central-container">
        <div class="glass-card match-card lobby-card">
            <h1 class="gradient-title">Sala de Jogo</h1>

            <div class="room-code-section lobby-code">
                <label>Código da sala:</label>
                <div class="code-display" id="room-code"><%= sala.codigoSala %></div>
            </div>

            <div class="players-list">
                <% sala.jogadores.forEach(jogador => { %>
                    <div class="player-slot" id="player-<%= String(jogador.id || jogador._id) %>">
                        <div class="avatar-container">
                            <img src="<%= jogador.avatar %>" alt="Jogador">
                            <div class="avatar-glow"></div>
                        </div>

                        <div class="player-name-badge">
                            <span><%= jogador.username %></span>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="actions-section" style="margin-top: 2rem; width: 100%; display: flex; justify-content: center;">
                <% 
                   // Lógica de verificação robusta
                   let eLider = false;
                   if (user && sala.jogadores.length > 0) {
                       const meuId = String(user.id || user._id);
                       const liderId = String(sala.jogadores[0].id || sala.jogadores[0]._id);
                       if (meuId === liderId) eLider = true;
                   }
                %>

                <% if (eLider) { %>
                    <button class="btn-create-match" id="btn-start-match">Iniciar partida</button>
                <% } else { %>
                    <p class="waiting-msg" style="color: white; font-style: italic; opacity: 0.8;">
                        A aguardar que o líder inicie a partida...
                    </p>
                <% } %>
            </div>
        </div>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <script type="module" src="/js/Socket/lobby-manager.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/lobby.js"></script>

</body>
</html>