<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scoreboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/scoreboard.css" />
  </head>
  <body>
    <main class="scoreboard-screen">
      <section class="scoreboard-card">

        <div class="sb-confetti" id="sb-confetti"></div>

        <p class="sb-winner-label" id="scoreboard-winner-title">Vencedor</p>
        <h1 class="winner" id="winner-display">A carregar...</h1>
        <p class="sb-winner-pts" id="winner-pts"></p>

        <div class="sb-divider"></div>

        <div class="ranking">
          <h3 id="scoreboard-ranking-title">Classificação</h3>
          <div id="ranking-list"></div>
        </div>

        <div class="buttons">
          <button id="btn-play-again" class="btn">▶ Jogar novamente</button>
          <a href="/hub" class="btn" id="btn-back-hub">← Voltar ao Hub</a>
        </div>

      </section>
    </main>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/scoreboard.js"></script>
  </body>
</html>
