<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scoreboard</title>
    <link rel="stylesheet" href="/css/scoreboard.css">
</head>
<body>
    <main class="scoreboard-screen">
        <section class="scoreboard-card">
            <h2 class="subtitle">Vencedor</h2>
            <h1 class="winner">Player_1 - 320 pts</h1>

            <div class="ranking">
                <h3>Classificação</h3>
                <p>1 - Player_1 - 320 pts</p>
                <p>2 - Player_2 - 280 pts</p>
                <p>3 - Player_3 - 200 pts</p>
            </div>

            <div class="buttons">
                <a href="/lobby" class="btn">Jogar novamente</a>
                <a href="/hub" class="btn">Voltar ao Hub</a>
            </div>
        </section>
    </main>
</body>
</html>