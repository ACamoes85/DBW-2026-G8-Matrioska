<!doctype html>
<html lang="pt-PT">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Matrioska - Perfil</title>
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/navbar.css" />
    <link rel="stylesheet" href="/css/profile.css" />
  </head>
  <body>
    <img src="/images/howtoplay_bg.png" class="background-image" alt="Fundo Perfil" />
    <div class="background-ellipse"></div>
    
    <a href="/hub" class="back-button"></a>
    
    <header class="header-navbar">
        <nav class="nav-links">
            <a href="/hub">Início</a>
            <a href="/leaderboard">Classificação</a>
            <a href="/howtoplay">Como jogar</a>
        </nav>
        <div class="profile-section">
            <a href="/profile" class="profile-link active-profile">
                <img src="/images/profile1.png" alt="Perfil" class="profile-avatar" id="nav-profile-avatar">
            </a>
        </div>
    </header>

    <main class="profile-page">
      <div class="glass-card profile-container">
        <div class="stats-section">
          <h1 class="title-neon" id="profile-title">Estatísticas</h1>
          
          <div class="stats-grid">
            <div class="stat-item">
              <p class="stat-label" id="stat-total-score">Pontuação Total</p>
              <p class="stat-value">500</p>
            </div>
            <div class="stat-item">
              <p class="stat-label" id="stat-correct">Respostas Corretas</p>
              <p class="stat-value">5</p>
            </div>
            <div class="stat-item">
              <p class="stat-label" id="stat-wrong">Respostas Erradas</p>
              <p class="stat-value">2</p>
            </div>
            <div class="stat-item">
              <p class="stat-label" id="stat-games">Partidas Jogadas</p>
              <p class="stat-value">1</p>
            </div>
          </div>
        </div>

        <div class="avatar-section">
          <h2 class="player-name" id="user-display-name">Player1</h2>

          <div class="avatar-circle-glow">
            <img src="/images/profile1.png" alt="User Avatar" class="large-avatar" id="main-profile-img">
          </div>
          
          <a href="/edit-profile" style="text-decoration: none;">
            <button class="btn-change-avatar" id="btn-change-photo">Alterar imagem de perfil</button>
          </a>
        </div>
      </div>
    </main>

    <script src="/js/main.js"></script>
  </body>
</html>